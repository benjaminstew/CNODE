#!/bin/bash
#PBS -N admm_mp_bioreactor
#PBS -l select=1:ncpus=40:mem=32gb
#PBS -l walltime=02:00:00
#PBS -j oe

# ---------------------------------------------------------------------------
# Conda environment
# ---------------------------------------------------------------------------
# PBS runs a non-interactive shell — 'conda activate' is not available unless
# conda has been initialised first. The most reliable approach is to source
# the conda init script explicitly, then activate.
# Find your conda base on the HPC with: conda info --base
source /rds/general/user/bms125/home/miniforge3/etc/profile.d/conda.sh
conda activate cnode

# ---------------------------------------------------------------------------
# Thread control (critical for 40-worker IPOPT jobs)
# ---------------------------------------------------------------------------
# Each of the 40 spawned worker processes runs a full IPOPT solve. Without
# this, libraries like OpenBLAS/MKL will spawn their own thread pools and you
# can easily end up with 40 × N_threads >> 40 active threads, causing severe
# oversubscription and slowdown. Pinning all thread counts to 1 ensures each
# worker uses exactly 1 core as requested.
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

# ---------------------------------------------------------------------------
# Unbuffered output — ensures print() calls appear in the job log in real time
# ---------------------------------------------------------------------------
export PYTHONUNBUFFERED=1

cd /rds/general/user/bms125/home/CNODE
python -m data.bioreactor_simulation.run_admm_mp
